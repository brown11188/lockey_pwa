NEXT_PUBLIC_BASE_PATH=          # e.g. /apps/myapp (empty = local dev at /)
DATABASE_URL=./data/app.db
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1
AUTH_SECRET=your-secret-here    # Generate with: pnpm dlx auth secret
AUTH_URL=http://localhost:3000  # Production: https://lockey-pwa.vercel.app
NEXTAUTH_URL=http://localhost:3000
